# DeepSeek API 配置（必需）
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-2afac1710d9543f7ab405afb8434fd31
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 语言配置
# 源语言: zh(中文), en(英语), ja(日语), de(德语)
SOURCE_LANGUAGE=en

# 目标语言: 支持同时翻译成多种语言，用逗号分隔
# 例如: zh (只翻译成中文)
#       zh,ja (同时翻译成中文和日语)
#       zh,en,ja,de (翻译成所有四种语言)
TARGET_LANGUAGES=zh,en,ja,de

# 音频配置
SAMPLE_RATE=16000
CHUNK_SIZE=1024
AUDIO_DEVICE_INDEX=-1

# ASR 配置
CORRECTION_WINDOW_SECONDS=15